{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Project-level allow + deny + hooks for headless claude -p. Required at <project_cwd>/.claude/settings.json (Anthropic: --add-dir paths do NOT contribute settings). Executor role uses --permission-mode dontAsk which lets ONLY allow-listed tools run; reviewer-likes use plan mode. roundtable-setup copies this file into the user's project root. Outside roundtable dispatch the hooks no-op silently.",
  "permissions": {
    "allow": [
      "Bash(chmod:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(ln:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(diff:*)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(tr:*)",
      "Bash(xargs:*)",
      "Bash(python3:*)",
      "Bash(python:*)",
      "Bash(bash scripts/*)",
      "Bash(bash *)",
      "Bash(git status:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git diff)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git rev-parse:*)",
      "Bash(git ls-files:*)",
      "Bash(git config user.email)",
      "Bash(git config user.name)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git restore:*)",
      "Bash(git restore --staged:*)",
      "Bash(git reset HEAD:*)",
      "Bash(git branch:*)",
      "Bash(git check-ignore:*)",
      "Bash(git stash:*)"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(git push)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(git reset --hard)",
      "Bash(git rebase:*)",
      "Bash(git rebase)",
      "Bash(git filter-branch:*)",
      "Bash(git update-ref:*)",
      "Read(./.env*)",
      "Read(./**/.env*)",
      "Read(~/.aws/**)",
      "Read(~/.ssh/**)",
      "Read(**/credentials*)",
      "Read(**/*secret*)",
      "Read(**/*.pem)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -n \"$ROUNDTABLE_HIST_DIR\" ]; then mkdir -p \"$ROUNDTABLE_HIST_DIR\" && { cat; printf '\\n'; } >> \"$ROUNDTABLE_HIST_DIR/edits.log\" 2>/dev/null || true; else cat >/dev/null; fi"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -n \"$ROUNDTABLE_HIST_DIR\" ]; then mkdir -p \"$ROUNDTABLE_HIST_DIR\" && cat > \"$ROUNDTABLE_HIST_DIR/stop.json\" 2>/dev/null || true; else cat >/dev/null; fi"
          }
        ]
      }
    ],
    "beforeShellExecution": [
      {
        "command": "<SKILL_DIR>/hooks/roundtable-dispatch-gate.sh",
        "matcher": "(codex|claude)_turn\\.sh",
        "failClosed": false,
        "_roundtable_id": "roundtable.h1.dispatch-gate"
      },
      {
        "command": "<SKILL_DIR>/hooks/roundtable-diversity-block.sh",
        "matcher": "reviewer-aggregator",
        "failClosed": false,
        "_roundtable_id": "roundtable.h2.diversity"
      },
      {
        "command": "<SKILL_DIR>/hooks/roundtable-budget-gate.sh",
        "matcher": "(codex|claude)_turn\\.sh",
        "failClosed": false,
        "_roundtable_id": "roundtable.h4.budget"
      }
    ],
    "postToolUse": [
      {
        "command": "<SKILL_DIR>/hooks/roundtable-oracle-post.sh",
        "matcher": "Shell",
        "failClosed": false,
        "_roundtable_id": "roundtable.h3.oracle"
      }
    ],
    "stop": [
      {
        "command": "<SKILL_DIR>/hooks/roundtable-autopilot-continue.sh",
        "failClosed": false,
        "loop_limit": 15,
        "_roundtable_id": "roundtable.h5.autopilot"
      }
    ]
  }
}
