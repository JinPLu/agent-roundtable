{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Project-level allow + deny + hooks for headless claude -p and Cursor third-party-hooks. Required at <project_cwd>/.claude/settings.json (Anthropic: --add-dir paths do NOT contribute settings; Cursor: per https://cursor.com/docs/reference/third-party-hooks Claude Code hook names auto-map to Cursor events). Executor role uses --permission-mode dontAsk which lets ONLY allow-listed tools run; reviewer-likes use plan mode. roundtable-setup copies this file into the user's project root, replacing <SKILL_DIR> with the absolute install path. Outside roundtable dispatch the hooks no-op silently.",
  "permissions": {
    "allow": [
      "Bash(chmod:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(ln:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(diff:*)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(tr:*)",
      "Bash(xargs:*)",
      "Bash(python3:*)",
      "Bash(python:*)",
      "Bash(bash scripts/*)",
      "Bash(bash *)",
      "Bash(git status:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git diff)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git rev-parse:*)",
      "Bash(git ls-files:*)",
      "Bash(git config user.email)",
      "Bash(git config user.name)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git restore:*)",
      "Bash(git restore --staged:*)",
      "Bash(git reset HEAD:*)",
      "Bash(git branch:*)",
      "Bash(git check-ignore:*)",
      "Bash(git stash:*)"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(git push)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(git reset --hard)",
      "Bash(git rebase:*)",
      "Bash(git rebase)",
      "Bash(git filter-branch:*)",
      "Bash(git update-ref:*)",
      "Read(./.env*)",
      "Read(./**/.env*)",
      "Read(~/.aws/**)",
      "Read(~/.ssh/**)",
      "Read(**/credentials*)",
      "Read(**/*secret*)",
      "Read(**/*.pem)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "<SKILL_DIR>/hooks/roundtable-dispatch-gate.sh",
            "_roundtable_id": "roundtable.h1.dispatch-gate"
          },
          {
            "type": "command",
            "command": "<SKILL_DIR>/hooks/roundtable-diversity-block.sh",
            "_roundtable_id": "roundtable.h2.diversity-block"
          },
          {
            "type": "command",
            "command": "<SKILL_DIR>/hooks/roundtable-budget-gate.sh",
            "_roundtable_id": "roundtable.h4.budget-gate"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -n \"$ROUNDTABLE_HIST_DIR\" ]; then mkdir -p \"$ROUNDTABLE_HIST_DIR\" && { cat; printf '\\n'; } >> \"$ROUNDTABLE_HIST_DIR/edits.log\" 2>/dev/null || true; else cat >/dev/null; fi"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "<SKILL_DIR>/hooks/roundtable-oracle-post.sh",
            "_roundtable_id": "roundtable.h3.oracle-post"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -n \"$ROUNDTABLE_HIST_DIR\" ]; then mkdir -p \"$ROUNDTABLE_HIST_DIR\" && cat > \"$ROUNDTABLE_HIST_DIR/stop.json\" 2>/dev/null || true; else cat >/dev/null; fi"
          },
          {
            "type": "command",
            "command": "<SKILL_DIR>/hooks/roundtable-autopilot-continue.sh",
            "_roundtable_id": "roundtable.h5.autopilot-continue"
          }
        ]
      }
    ]
  }
}
